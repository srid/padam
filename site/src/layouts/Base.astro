---
interface Props { title?: string }
const { title = "padam" } = Astro.props;
const base = import.meta.env.BASE_URL;
const desc = "Prompt your agent to make videos — a Remotion video engine driven by an editable storyboard.json.";
const ogImage = new URL(`${base}og.png`, Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const nav = [
  { href: base, label: "padam" },
  { href: `${base}videos/`, label: "Now Showing" },
  { href: "https://github.com/srid/padam", label: "GitHub" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="padam" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <style is:global>
      /* ── Vintage Tamil single-screen cinema (Sivaji era): oxblood + brass + aged paper ── */
      :root {
        --ink: #160a08; --maroon: #3a1410; --maroon-2: #2a0e0b;
        --gold: #e0b23a; --gold-2: #f4d784; --brass: #c79a32;
        --cream: #f3e7cd; --cream-dim: #cdbb94; --red: #c0392b;
        --paper: #efe2c2; --paper-ink: #2b1a12;
        --serif: "Playfair Display", "Georgia", "Times New Roman", serif;
        --sans: "Optima", "Palatino Linotype", "Georgia", serif;
        --mono: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0; color: var(--cream); font-family: var(--sans); line-height: 1.55;
        background:
          radial-gradient(120% 80% at 50% -10%, #5a1e16 0%, var(--maroon-2) 38%, var(--ink) 78%) fixed;
      }
      a { color: var(--gold-2); text-decoration: none; }
      a:hover { color: #fff; }

      /* marquee bulb strip */
      .bulbs {
        height: 16px;
        background: radial-gradient(circle at 14px 50%, var(--gold-2) 0 3.5px, rgba(224,178,58,.15) 4.5px, transparent 5.5px) repeat-x;
        background-size: 32px 16px;
        filter: drop-shadow(0 0 5px rgba(244,215,132,.55));
        border-bottom: 1px solid rgba(224,178,58,.25);
      }

      header {
        display: flex; align-items: center; justify-content: space-between; gap: 18px;
        padding: 16px clamp(18px, 5vw, 56px);
        border-bottom: 1px solid rgba(224,178,58,.22);
        background: linear-gradient(180deg, rgba(58,20,16,.55), transparent);
      }
      header .brand img { height: 54px; width: auto; display: block;
        filter: drop-shadow(0 2px 6px rgba(0,0,0,.6)); }
      header nav { display: flex; gap: clamp(14px, 3vw, 34px); align-items: center; }
      header nav a {
        font-family: var(--serif); font-size: 18px; letter-spacing: 1.5px;
        text-transform: uppercase; color: var(--cream); padding-bottom: 3px;
        border-bottom: 2px solid transparent;
      }
      header nav a:hover { color: var(--gold-2); border-color: var(--gold); }

      main { max-width: 1080px; margin: 0 auto; padding: clamp(28px, 5vw, 64px) 22px 90px; }

      h1, h2, h3 { font-family: var(--serif); color: var(--cream); font-weight: 800; }
      h1 { font-size: clamp(40px, 7vw, 76px); line-height: 1.04; margin: 0 0 14px; }
      h2 { font-size: clamp(26px, 4vw, 38px); margin: 0 0 18px; }
      .eyebrow { font-family: var(--mono); letter-spacing: 5px; text-transform: uppercase;
        color: var(--gold); font-size: 13px; }
      .lede { color: var(--cream-dim); font-size: clamp(17px, 2.4vw, 21px); max-width: 60ch; }
      code { font-family: var(--mono); background: rgba(0,0,0,.35); border: 1px solid rgba(224,178,58,.25);
        border-radius: 6px; padding: 1px 7px; font-size: .9em; color: var(--gold-2); }

      /* brass rule with a center diamond */
      .rule { display: flex; align-items: center; gap: 16px; margin: 46px 0; color: var(--gold); }
      .rule::before, .rule::after { content: ""; height: 1px; flex: 1;
        background: linear-gradient(90deg, transparent, var(--brass), transparent); }
      .rule span { font-size: 14px; }

      /* "NOW SHOWING" brass plaque */
      .plaque { display: inline-block; font-family: var(--mono); letter-spacing: 4px;
        text-transform: uppercase; font-size: 13px; color: var(--ink);
        background: linear-gradient(180deg, var(--gold-2), var(--brass));
        padding: 6px 16px; border-radius: 4px; box-shadow: 0 2px 0 #7a5c14, 0 4px 10px rgba(0,0,0,.5); }

      .btn { display: inline-block; font-family: var(--serif); font-size: 18px; letter-spacing: 1px;
        padding: 12px 24px; border-radius: 6px; border: 2px solid var(--gold);
        color: var(--gold-2); background: rgba(224,178,58,.06); transition: all .15s; }
      .btn:hover { background: var(--gold); color: var(--ink); }
      .btn.solid { background: linear-gradient(180deg, var(--gold-2), var(--brass)); color: var(--ink); border-color: var(--brass); }
      .btn.solid:hover { filter: brightness(1.08); color: var(--ink); }
      .btns { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 28px; }

      /* lobby-card grid */
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 26px; }
      .card { display: block; background: var(--paper); color: var(--paper-ink);
        border: 1px solid var(--brass); border-radius: 10px; overflow: hidden;
        box-shadow: 0 10px 26px rgba(0,0,0,.5); transition: transform .15s, box-shadow .15s; }
      .card:hover { transform: translateY(-4px); box-shadow: 0 16px 36px rgba(0,0,0,.6); text-decoration: none; }
      .card video, .card .thumb { width: 100%; display: block; background: #000; aspect-ratio: 16/9; object-fit: contain; border-bottom: 3px solid var(--gold); }
      .card .meta { padding: 14px 16px; }
      .card .meta strong { display: block; font-family: var(--serif); font-size: 20px; color: var(--maroon); }
      .card .meta span { color: #7a5c3a; font-family: var(--mono); font-size: 12.5px; letter-spacing: .5px; }

      /* chips */
      .chips { display: flex; flex-wrap: wrap; gap: 10px; }
      .chip { font-family: var(--mono); font-size: 14px; color: var(--gold-2);
        border: 1px solid var(--brass); border-radius: 999px; padding: 6px 14px; background: rgba(0,0,0,.25); }

      /* the "screen": framed video on a detail page */
      .screen { width: 100%; border-radius: 8px; background: #000;
        border: 3px solid var(--gold); box-shadow: 0 0 0 8px var(--maroon), 0 18px 40px rgba(0,0,0,.6); }
      ol.programme { font-family: var(--mono); padding-left: 22px; }
      ol.programme li { margin: 7px 0; color: var(--cream-dim); }
      ol.programme li code { color: var(--gold-2); }

      /* film-strip footer */
      footer { margin-top: 60px; }
      .filmstrip { position: relative; height: 38px; background: #0a0604; border-top: 1px solid rgba(224,178,58,.2); }
      .filmstrip::before, .filmstrip::after { content: ""; position: absolute; left: 0; right: 0; height: 8px;
        background: repeating-linear-gradient(90deg, rgba(224,178,58,.35) 0 12px, transparent 12px 30px); }
      .filmstrip::before { top: 7px; } .filmstrip::after { bottom: 7px; }
      .colophon { text-align: center; color: var(--cream-dim); font-family: var(--mono); font-size: 13px; padding: 20px; }
      .colophon a { color: var(--gold-2); }
    </style>
  </head>
  <body>
    <div class="bulbs"></div>
    <header>
      <a class="brand" href={base}><img src={`${base}padam-logo.png`} alt="padam" /></a>
      <nav>{nav.map((n) => <a href={n.href}>{n.label}</a>)}</nav>
    </header>
    <main><slot /></main>
    <footer>
      <div class="filmstrip"></div>
      <div class="colophon">
        a single-screen production · <a href="https://github.com/srid/padam">github.com/srid/padam</a> · AGPL-3.0 · Remotion + Nix
      </div>
    </footer>
  </body>
</html>
