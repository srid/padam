---
import Base from "../layouts/Base.astro";
import videos from "../data/videos.json";
const base = import.meta.env.BASE_URL;
const count = videos.length;
const steps = [
  { n: "1", t: "Ask", d: "Tell your agent what you want — “a 30-second launch clip, dark, square.” It writes a storyboard.json." },
  { n: "2", t: "Refine", d: "“Make the title longer, add a subtitle.” The agent edits a few lines of JSON." },
  { n: "3", t: "Render", d: "One command renders a deterministic MP4 with Remotion — reproducible from the storyboard alone." },
];
const kinds = ["title", "bullets", "code", "diff", "terminal", "quote", "image", "stats", "outro", "custom"];
---

<Base title="padam — prompt your agent to make videos">
  <section class="hero">
    <p class="eyebrow">படம் — Tamil for “movie”</p>
    <h1>Prompt your agent<br />to make videos.</h1>
    <p class="lede">
      padam turns a hand- or agent-editable <code>storyboard.json</code> into a deterministic MP4
      (Remotion&nbsp;+&nbsp;Nix). You direct; your agent edits and renders — and even watches the
      frames to refine.
    </p>
    <div class="btns">
      <a class="btn solid" href={`${base}videos/tutorial/`}>▶ Watch the tutorial</a>
      <a class="btn" href={`${base}videos/`}>Now Showing{count ? ` (${count})` : ""}</a>
      <a class="btn" href="https://github.com/srid/padam">GitHub</a>
    </div>
    <img class="hero-banner" src={`${base}og.png`} alt="padam — now showing: lights, camera, prompt" />
  </section>

  <div class="rule"><span>✦</span></div>

  <h2>How it works</h2>
  <div class="steps">
    {steps.map((s) => (
      <div class="step">
        <div class="step-n">{s.n}</div>
        <div><h3>{s.t}</h3><p>{s.d}</p></div>
      </div>
    ))}
  </div>

  <div class="rule"><span>✦</span></div>

  <h2>What’s in the box</h2>
  <p class="lede">
    A catalog of scene kinds you compose in JSON — plus a <code>custom</code> escape hatch for real
    React/Remotion when a shot needs bespoke motion.
  </p>
  <div class="chips" style="margin-top:18px">{kinds.map((k) => <span class="chip">{k}</span>)}</div>

  <div class="rule"><span>✦</span></div>

  <section class="closing">
    <p class="plaque">Now Showing</p>
    <h2 style="margin-top:16px">{count} {count === 1 ? "feature" : "features"} in the gallery</h2>
    <p class="lede">Every video is reproducible from its storyboard — browse them, or clone the repo and make your own.</p>
    <div class="btns" style="justify-content:center"><a class="btn solid" href={`${base}videos/`}>Enter the gallery →</a></div>
  </section>

  <style>
    .hero-banner { width: 100%; margin-top: 36px; border-radius: 10px; border: 1px solid var(--brass); box-shadow: 0 16px 40px rgba(0,0,0,.55); }
    .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 22px; }
    .step { display: flex; gap: 16px; background: rgba(0,0,0,.22); border: 1px solid rgba(224,178,58,.25); border-radius: 10px; padding: 20px; }
    .step-n { font-family: var(--serif); font-size: 42px; color: var(--gold); line-height: 1; }
    .step h3 { margin: 0 0 6px; color: var(--gold-2); font-size: 22px; }
    .step p { margin: 0; color: var(--cream-dim); }
    .closing { text-align: center; }
    .closing .lede { margin-left: auto; margin-right: auto; }
  </style>
</Base>
