{
  "title": "padam — a tutorial",
  "fps": 30,
  "width": 1920,
  "height": 1080,
  "scenes": [
    {
      "id": "banner",
      "kind": "image",
      "durationInFrames": 80,
      "src": "banner.png",
      "caption": "padam — Tamil for \"movie\". Now showing:"
    },
    {
      "id": "intro",
      "kind": "title",
      "durationInFrames": 90,
      "eyebrow": "a 60-second tutorial",
      "heading": "lights, camera, prompt",
      "sub": "make videos by talking to your agent"
    },
    {
      "id": "what",
      "kind": "bullets",
      "durationInFrames": 150,
      "heading": "What is padam?",
      "items": [
        "A video is a storyboard.json — an ordered list of scenes",
        "You describe the cut in plain JSON; your agent edits it",
        "padam renders a deterministic MP4 (Remotion + Nix)"
      ],
      "caption": "This very video is a padam. Yes, we dogfood."
    },
    {
      "id": "ask",
      "kind": "custom",
      "component": "ClaudePrompt",
      "durationInFrames": 175,
      "props": {
        "cwd": "~/code/site",
        "prompt": "make a 30-second launch clip — dark, square for LinkedIn",
        "response": "● writing videos/demo/storyboard.json …"
      },
      "caption": "1 · Ask — you prompt; the agent writes the storyboard."
    },
    {
      "id": "result",
      "kind": "code",
      "durationInFrames": 150,
      "file": "videos/demo/storyboard.json",
      "lang": "json",
      "code": "{\n  \"title\": \"my first video\",\n  \"width\": 1080, \"height\": 1080, \"fps\": 30,\n  \"scenes\": [\n    { \"kind\": \"title\", \"durationInFrames\": 90,\n      \"heading\": \"Hello!\" },\n    { \"kind\": \"outro\", \"durationInFrames\": 90,\n      \"heading\": \"Bye\", \"chips\": [\"made with padam\"] }\n  ]\n}",
      "caption": "Each scene is just a kind + a few fields."
    },
    {
      "id": "kinds",
      "kind": "stats",
      "durationInFrames": 110,
      "heading": "Scene kinds in the box",
      "chips": ["title", "bullets", "code", "diff", "terminal", "quote", "image", "stats", "outro", "custom"]
    },
    {
      "id": "refine",
      "kind": "custom",
      "component": "ClaudePrompt",
      "durationInFrames": 165,
      "props": {
        "cwd": "~/code/site",
        "prompt": "make the title longer and add a subtitle",
        "response": "● editing videos/demo/storyboard.json …"
      },
      "caption": "2 · Refine — just say what you want changed."
    },
    {
      "id": "refine-diff",
      "kind": "diff",
      "durationInFrames": 150,
      "file": "videos/demo/storyboard.json",
      "lang": "json",
      "before": "{ \"kind\": \"title\",\n  \"durationInFrames\": 90,\n  \"heading\": \"Hello!\" }",
      "after": "{ \"kind\": \"title\",\n  \"durationInFrames\": 120,\n  \"heading\": \"Hello, world!\",\n  \"sub\": \"my first padam\" }",
      "caption": "… and the agent makes exactly that edit."
    },
    {
      "id": "render",
      "kind": "terminal",
      "durationInFrames": 110,
      "command": "just render demo",
      "output": "render: ✓ videos/demo/out.mp4",
      "caption": "3 · Render — reproducible from the storyboard alone."
    },
    {
      "id": "quote",
      "kind": "quote",
      "durationInFrames": 120,
      "text": "The best video editor is the one you never have to open.",
      "by": "every padam user, probably"
    },
    {
      "id": "customize",
      "kind": "bullets",
      "durationInFrames": 140,
      "heading": "Make it yours",
      "items": [
        "Theme: override colors + fonts per storyboard",
        "Aspect: 16:9, 9:16, or 1:1 via width / height",
        "Custom motion: drop a .tsx scene (kind: \"custom\")"
      ],
      "caption": "Plain JSON for 90% — real React when you need it."
    },
    {
      "id": "outro",
      "kind": "outro",
      "durationInFrames": 110,
      "heading": "That's a wrap.",
      "sub": "github.com/srid/padam",
      "chips": ["Remotion", "Nix", "agent-editable", "AGPL"]
    }
  ]
}
